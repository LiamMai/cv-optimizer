{
  "name": "cv-optimizer",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "dev": "pnpm db:up && concurrently \"pnpm --filter @cv-optimizer/web dev\" \"pnpm --filter cv-optimizer-api dev\"",
    "build": "pnpm --filter @cv-optimizer/web build && pnpm --filter cv-optimizer-api build",
    "dev:web": "pnpm --filter @cv-optimizer/web dev",
    "dev:api": "pnpm --filter cv-optimizer-api dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
