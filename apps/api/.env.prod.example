# ============================================================
# API PRODUCTION ENV — copy to apps/api/.env.prod
# ============================================================

# Database — hostname is "postgres" (docker service name)
DATABASE_URL="postgresql://cvoptimizer:CHANGE_ME_STRONG_PASSWORD@postgres:5432/cv_optimizer"

# Session & Encryption — generate: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_64_HEX_CHARS
SESSION_SECRET=GENERATE_64_HEX_CHARS
SESSION_TTL_HOURS=2

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/api/v1/auth/google/callback

# AI fallback (optional — users bring own credentials via session)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Server
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://YOUR_DOMAIN
CORS_ORIGIN=https://YOUR_DOMAIN
JWT_SECRET=GENERATE_64_HEX_CHARS

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
